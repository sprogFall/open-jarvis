# ---------- 应用 ----------
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=INFO

# ---------- PostgreSQL ----------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=jarvis
POSTGRES_PASSWORD=jarvis
POSTGRES_DB=open_jarvis
DATABASE_URL=postgresql+asyncpg://jarvis:jarvis@localhost:5432/open_jarvis

# ---------- Redis ----------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://localhost:6379/0

# ---------- LLM ----------
# 模型供应商密钥按需配置，仅从环境变量注入，不进入代码与日志
OPENAI_API_KEY=
OPENAI_API_URL=

# 模型路由
LLM_FAST_MODEL=gpt-4o-mini
LLM_STANDARD_MODEL=gpt-4o
LLM_REASONING_MODEL=o3-mini
LLM_TEMPERATURE=0
LLM_REQUEST_TIMEOUT=60
LLM_MAX_RETRIES=2
# DEBUG 会输出触发 SDK 自动重试的底层网络异常或 HTTP 状态，不记录 Prompt/响应正文
LLM_SDK_LOG_LEVEL=DEBUG

# ---------- 可观测性 ----------
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=open-jarvis
