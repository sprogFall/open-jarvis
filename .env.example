# ---------- 应用 ----------
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=INFO

# ---------- PostgreSQL ----------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=jarvis
POSTGRES_PASSWORD=jarvis
POSTGRES_DB=open_jarvis
DATABASE_URL=postgresql+asyncpg://jarvis:jarvis@localhost:5432/open_jarvis

# ---------- Redis ----------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://localhost:6379/0

# ---------- LLM ----------
# 模型供应商密钥按需配置，仅从环境变量注入，不进入代码与日志
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ---------- 可观测性 ----------
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=open-jarvis
