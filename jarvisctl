#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ENV_FILE="${JARVISCTL_ENV_FILE:-$ROOT_DIR/.env}"
ENV_TEMPLATE_FILE="${JARVISCTL_ENV_TEMPLATE:-$ROOT_DIR/.env.example}"
DRY_RUN="${JARVISCTL_DRY_RUN:-0}"

ACTION="${1:-menu}"
if [[ $# -gt 0 ]]; then
  shift
fi
CLI_TARGET_ARGS=("$@")

VALID_TARGETS=(postgres gateway client dashboard)
FULL_STACK_TARGETS=(postgres gateway client dashboard)
RUNTIME_TARGETS=(gateway client dashboard)
ISSUE_ORDER=(
  DATABASE_URL
  POSTGRES_PASSWORD
  OMNI_AGENT_JWT_SECRET
  OMNI_AGENT_ADMIN_USERNAME
  OMNI_AGENT_ADMIN_PASSWORD
  VITE_GATEWAY_BASE_URL
  OMNI_AGENT_GATEWAY_URL
  OMNI_AGENT_DEVICE_KEYS
  OMNI_AGENT_DEVICE_ID
  OMNI_AGENT_DEVICE_KEY
)

POSTGRES_PASSWORD_DEFAULT="jarvis"
JWT_SECRET_DEFAULT="change-me-change-me-change-me-1234"
ADMIN_PASSWORD_DEFAULT="passw0rd"
DEVICE_KEY_DEFAULT="device-secret"
CN_APT_MIRROR_HOST="mirrors.tuna.tsinghua.edu.cn"
CN_PIP_INDEX_URL="https://pypi.tuna.tsinghua.edu.cn/simple"
CN_PIP_TRUSTED_HOST="pypi.tuna.tsinghua.edu.cn"
CN_NPM_REGISTRY="https://registry.npmmirror.com"

TEMPLATE_LINES=()
declare -A TEMPLATE_VALUES=()
declare -A ENV_VALUES=()
declare -A EFFECTIVE_VALUES=()
declare -A SKIPPED_DEFAULT_KEYS=()
ISSUE_KEYS=()
ISSUE_REASONS=()
FILTERED_ISSUE_KEYS=()
FILTERED_ISSUE_REASONS=()
DEVICE_IDS=()
DEVICE_SECRETS=()
TARGETS=()
RESOLVED_SERVICES=()
COMPOSE_CMD=()
PROMPT_RESULT=""
PROMPT_SKIPPED="0"
REQUESTED_TARGET_ARGS=()
REQUESTED_NETWORK_PROFILE=""

trim() {
  local value="${1-}"
  value="${value#"${value%%[![:space:]]*}"}"
  value="${value%"${value##*[![:space:]]}"}"
  printf '%s' "$value"
}

array_contains() {
  local needle="$1"
  shift
  local item
  for item in "$@"; do
    if [[ "$item" == "$needle" ]]; then
      return 0
    fi
  done
  return 1
}

assignment_key() {
  local raw_line="$1"
  printf '%s' "$(trim "${raw_line%%=*}")"
}

assignment_value() {
  local raw_line="$1"
  printf '%s' "$(trim "${raw_line#*=}")"
}

is_assignment_line() {
  local raw_line="$1"
  [[ "$raw_line" =~ ^[[:space:]]*# ]] && return 1
  [[ "$raw_line" == *"="* ]]
}

set_default_targets() {
  case "${1:-full}" in
    runtime)
      TARGETS=("${RUNTIME_TARGETS[@]}")
      ;;
    *)
      TARGETS=("${FULL_STACK_TARGETS[@]}")
      ;;
  esac
}

normalize_targets() {
  local default_mode="${1:-full}"
  shift || true
  local raw chunk candidate
  TARGETS=()
  if [[ $# -eq 0 ]]; then
    set_default_targets "$default_mode"
    return 0
  fi

  for raw in "$@"; do
    IFS=',' read -r -a chunk <<< "$raw"
    for candidate in "${chunk[@]}"; do
      candidate="$(trim "$candidate")"
      [[ -z "$candidate" ]] && continue
      if [[ "$candidate" == "all" ]]; then
        set_default_targets "$default_mode"
        return 0
      fi
      if ! array_contains "$candidate" "${VALID_TARGETS[@]}"; then
        echo "不支持的目标: $candidate" >&2
        return 1
      fi
      if ! array_contains "$candidate" "${TARGETS[@]}"; then
        TARGETS+=("$candidate")
      fi
    done
  done

  if [[ ${#TARGETS[@]} -eq 0 ]]; then
    set_default_targets "$default_mode"
  fi
}

resolve_deploy_services() {
  normalize_targets full "$@"
  RESOLVED_SERVICES=("${TARGETS[@]}")
}

should_skip_compose_dependencies() {
  [[ $# -eq 1 ]] || return 1
  case "$1" in
    gateway|client|dashboard) return 0 ;;
    *) return 1 ;;
  esac
}

is_absolute_http_url() {
  [[ "$1" =~ ^https?://[^[:space:]/]+(:[0-9]+)?(/.*)?$ ]]
}

extract_http_host() {
  local url="$1"
  local host=""
  if [[ "$url" =~ ^https?://\[?([^]/:]+)\]?(:[0-9]+)?(/.*)?$ ]]; then
    host="${BASH_REMATCH[1],,}"
  fi
  printf '%s' "$host"
}

has_compose_only_hostname() {
  local url="$1"
  shift
  local host candidate
  host="$(extract_http_host "$url")"
  [[ -n "$host" ]] || return 1
  for candidate in "$@"; do
    if [[ "$host" == "$candidate" ]]; then
      return 0
    fi
  done
  return 1
}

database_url_needs_external_dependency() {
  local value
  value="$(trim "${1-}")"
  [[ -n "$value" ]] || return 0
  if [[ "$value" =~ ^postgres[^:]*://([^@/]+@)?postgres([/:]|$) ]]; then
    return 0
  fi
  return 1
}

apply_network_profile_defaults() {
  local profile
  profile="$(trim "${EFFECTIVE_VALUES[DEPLOY_NETWORK_PROFILE]-}")"
  [[ -n "$profile" ]] || profile="global"
  case "$profile" in
    global|cn) ;;
    *) profile="global" ;;
  esac
  EFFECTIVE_VALUES[DEPLOY_NETWORK_PROFILE]="$profile"

  if [[ "$profile" == "cn" ]]; then
    if [[ -z "${ENV_VALUES[GATEWAY_DOCKERFILE]-}" || "${EFFECTIVE_VALUES[GATEWAY_DOCKERFILE]-}" == "gateway/Dockerfile" || "${EFFECTIVE_VALUES[GATEWAY_DOCKERFILE]-}" == "gateway/Dockerfile.cn" ]]; then
      EFFECTIVE_VALUES[GATEWAY_DOCKERFILE]="gateway/Dockerfile.cn"
    fi
    if [[ -z "${ENV_VALUES[CLIENT_DOCKERFILE]-}" || "${EFFECTIVE_VALUES[CLIENT_DOCKERFILE]-}" == "client/Dockerfile" || "${EFFECTIVE_VALUES[CLIENT_DOCKERFILE]-}" == "client/Dockerfile.cn" ]]; then
      EFFECTIVE_VALUES[CLIENT_DOCKERFILE]="client/Dockerfile.cn"
    fi
    if [[ -z "${ENV_VALUES[DASHBOARD_DOCKERFILE]-}" || "${EFFECTIVE_VALUES[DASHBOARD_DOCKERFILE]-}" == "dashboard/Dockerfile" || "${EFFECTIVE_VALUES[DASHBOARD_DOCKERFILE]-}" == "dashboard/Dockerfile.cn" ]]; then
      EFFECTIVE_VALUES[DASHBOARD_DOCKERFILE]="dashboard/Dockerfile.cn"
    fi
    if [[ -z "${ENV_VALUES[APT_MIRROR_HOST]-}" || "${EFFECTIVE_VALUES[APT_MIRROR_HOST]-}" == "$CN_APT_MIRROR_HOST" ]]; then
      EFFECTIVE_VALUES[APT_MIRROR_HOST]="$CN_APT_MIRROR_HOST"
    fi
    if [[ -z "${ENV_VALUES[PIP_INDEX_URL]-}" || "${EFFECTIVE_VALUES[PIP_INDEX_URL]-}" == "$CN_PIP_INDEX_URL" ]]; then
      EFFECTIVE_VALUES[PIP_INDEX_URL]="$CN_PIP_INDEX_URL"
    fi
    if [[ -z "${ENV_VALUES[PIP_TRUSTED_HOST]-}" || "${EFFECTIVE_VALUES[PIP_TRUSTED_HOST]-}" == "$CN_PIP_TRUSTED_HOST" ]]; then
      EFFECTIVE_VALUES[PIP_TRUSTED_HOST]="$CN_PIP_TRUSTED_HOST"
    fi
    if [[ -z "${ENV_VALUES[DASHBOARD_NPM_REGISTRY]-}" || "${EFFECTIVE_VALUES[DASHBOARD_NPM_REGISTRY]-}" == "$CN_NPM_REGISTRY" ]]; then
      EFFECTIVE_VALUES[DASHBOARD_NPM_REGISTRY]="$CN_NPM_REGISTRY"
    fi
  else
    if [[ -z "${ENV_VALUES[GATEWAY_DOCKERFILE]-}" || "${EFFECTIVE_VALUES[GATEWAY_DOCKERFILE]-}" == "gateway/Dockerfile.cn" ]]; then
      EFFECTIVE_VALUES[GATEWAY_DOCKERFILE]="gateway/Dockerfile"
    fi
    if [[ -z "${ENV_VALUES[CLIENT_DOCKERFILE]-}" || "${EFFECTIVE_VALUES[CLIENT_DOCKERFILE]-}" == "client/Dockerfile.cn" ]]; then
      EFFECTIVE_VALUES[CLIENT_DOCKERFILE]="client/Dockerfile"
    fi
    if [[ -z "${ENV_VALUES[DASHBOARD_DOCKERFILE]-}" || "${EFFECTIVE_VALUES[DASHBOARD_DOCKERFILE]-}" == "dashboard/Dockerfile.cn" ]]; then
      EFFECTIVE_VALUES[DASHBOARD_DOCKERFILE]="dashboard/Dockerfile"
    fi
    if [[ -z "${ENV_VALUES[APT_MIRROR_HOST]-}" || "${EFFECTIVE_VALUES[APT_MIRROR_HOST]-}" == "$CN_APT_MIRROR_HOST" ]]; then
      EFFECTIVE_VALUES[APT_MIRROR_HOST]=""
    fi
    if [[ -z "${ENV_VALUES[PIP_INDEX_URL]-}" || "${EFFECTIVE_VALUES[PIP_INDEX_URL]-}" == "$CN_PIP_INDEX_URL" ]]; then
      EFFECTIVE_VALUES[PIP_INDEX_URL]=""
    fi
    if [[ -z "${ENV_VALUES[PIP_TRUSTED_HOST]-}" || "${EFFECTIVE_VALUES[PIP_TRUSTED_HOST]-}" == "$CN_PIP_TRUSTED_HOST" ]]; then
      EFFECTIVE_VALUES[PIP_TRUSTED_HOST]=""
    fi
    if [[ -z "${ENV_VALUES[DASHBOARD_NPM_REGISTRY]-}" || "${EFFECTIVE_VALUES[DASHBOARD_NPM_REGISTRY]-}" == "$CN_NPM_REGISTRY" ]]; then
      EFFECTIVE_VALUES[DASHBOARD_NPM_REGISTRY]=""
    fi
  fi
}

load_template() {
  local raw_line key value
  [[ -f "$ENV_TEMPLATE_FILE" ]] || {
    echo "缺少模板文件: $ENV_TEMPLATE_FILE" >&2
    exit 1
  }

  TEMPLATE_LINES=()
  TEMPLATE_VALUES=()

  while IFS= read -r raw_line || [[ -n "$raw_line" ]]; do
    TEMPLATE_LINES+=("$raw_line")
    if is_assignment_line "$raw_line"; then
      key="$(assignment_key "$raw_line")"
      value="$(assignment_value "$raw_line")"
      TEMPLATE_VALUES["$key"]="$value"
    fi
  done < "$ENV_TEMPLATE_FILE"
}

load_env_file() {
  local raw_line key value
  ENV_VALUES=()
  if [[ ! -f "$ENV_FILE" ]]; then
    return 0
  fi

  while IFS= read -r raw_line || [[ -n "$raw_line" ]]; do
    if ! is_assignment_line "$raw_line"; then
      continue
    fi
    key="$(assignment_key "$raw_line")"
    value="$(assignment_value "$raw_line")"
    ENV_VALUES["$key"]="$value"
  done < "$ENV_FILE"
}

upsert_device_pair() {
  local target_id="$1"
  local target_secret="$2"
  local idx
  for idx in "${!DEVICE_IDS[@]}"; do
    if [[ "${DEVICE_IDS[$idx]}" == "$target_id" ]]; then
      DEVICE_SECRETS[$idx]="$target_secret"
      return 0
    fi
  done
  DEVICE_IDS+=("$target_id")
  DEVICE_SECRETS+=("$target_secret")
}

parse_device_registry() {
  local raw_value pair device_id device_secret
  DEVICE_IDS=()
  DEVICE_SECRETS=()
  raw_value="$(trim "${1-}")"
  [[ -z "$raw_value" ]] && return 0

  IFS=',' read -r -a pair <<< "$raw_value"
  local item
  for item in "${pair[@]}"; do
    item="$(trim "$item")"
    [[ -z "$item" ]] && continue
    [[ "$item" == *"="* ]] || return 1
    device_id="$(trim "${item%%=*}")"
    device_secret="$(trim "${item#*=}")"
    [[ -n "$device_id" && -n "$device_secret" ]] || return 1
    upsert_device_pair "$device_id" "$device_secret"
  done
  return 0
}

registry_get_secret() {
  local target_id="$1"
  local idx
  for idx in "${!DEVICE_IDS[@]}"; do
    if [[ "${DEVICE_IDS[$idx]}" == "$target_id" ]]; then
      printf '%s' "${DEVICE_SECRETS[$idx]}"
      return 0
    fi
  done
  return 1
}

serialize_device_registry() {
  local idx output=""
  for idx in "${!DEVICE_IDS[@]}"; do
    [[ -n "$output" ]] && output+=","
    output+="${DEVICE_IDS[$idx]}=${DEVICE_SECRETS[$idx]}"
  done
  printf '%s' "$output"
}

build_effective_values() {
  local key raw_registry device_id device_key matched_secret
  EFFECTIVE_VALUES=()
  for key in "${!TEMPLATE_VALUES[@]}"; do
    EFFECTIVE_VALUES["$key"]="${TEMPLATE_VALUES[$key]}"
  done
  for key in "${!ENV_VALUES[@]}"; do
    EFFECTIVE_VALUES["$key"]="${ENV_VALUES[$key]}"
  done
  apply_network_profile_defaults

  raw_registry="${EFFECTIVE_VALUES[OMNI_AGENT_DEVICE_KEYS]-}"
  parse_device_registry "$raw_registry" || {
    DEVICE_IDS=()
    DEVICE_SECRETS=()
  }

  device_id="$(trim "${EFFECTIVE_VALUES[OMNI_AGENT_DEVICE_ID]-}")"
  device_key="$(trim "${EFFECTIVE_VALUES[OMNI_AGENT_DEVICE_KEY]-}")"

  if [[ -n "$device_id" && -n "$device_key" ]]; then
    upsert_device_pair "$device_id" "$device_key"
    EFFECTIVE_VALUES[OMNI_AGENT_DEVICE_ID]="$device_id"
    EFFECTIVE_VALUES[OMNI_AGENT_DEVICE_KEY]="$device_key"
  elif [[ -n "$device_id" && -z "$device_key" ]]; then
    matched_secret="$(registry_get_secret "$device_id" || true)"
    if [[ -n "$matched_secret" ]]; then
      EFFECTIVE_VALUES[OMNI_AGENT_DEVICE_KEY]="$matched_secret"
    fi
  elif [[ -z "$device_id" && ${#DEVICE_IDS[@]} -gt 0 ]]; then
    EFFECTIVE_VALUES[OMNI_AGENT_DEVICE_ID]="${DEVICE_IDS[0]}"
    EFFECTIVE_VALUES[OMNI_AGENT_DEVICE_KEY]="${DEVICE_SECRETS[0]}"
  fi

  if [[ ${#DEVICE_IDS[@]} -gt 0 ]]; then
    EFFECTIVE_VALUES[OMNI_AGENT_DEVICE_KEYS]="$(serialize_device_registry)"
  fi
}

field_label() {
  case "$1" in
    DATABASE_URL) printf 'Gateway 数据库连接' ;;
    POSTGRES_PASSWORD) printf 'PostgreSQL 密码' ;;
    OMNI_AGENT_JWT_SECRET) printf 'JWT 密钥' ;;
    OMNI_AGENT_ADMIN_USERNAME) printf '管理员账号' ;;
    OMNI_AGENT_ADMIN_PASSWORD) printf '管理员密码' ;;
    VITE_GATEWAY_BASE_URL) printf 'Dashboard API 基地址' ;;
    OMNI_AGENT_GATEWAY_URL) printf 'Client Gateway 地址' ;;
    OMNI_AGENT_DEVICE_KEYS) printf '设备注册表' ;;
    OMNI_AGENT_DEVICE_ID) printf '客户端设备 ID' ;;
    OMNI_AGENT_DEVICE_KEY) printf '客户端设备密钥' ;;
