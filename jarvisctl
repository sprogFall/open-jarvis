field_is_secret() {
  case "$1" in
    DATABASE_URL|POSTGRES_PASSWORD|OMNI_AGENT_JWT_SECRET|OMNI_AGENT_ADMIN_PASSWORD|OMNI_AGENT_DEVICE_KEY) return 0 ;;
    *) return 1 ;;
  esac
}

reason_text() {
  case "$1" in
    missing) printf '未配置' ;;
    example_default) printf '仍是示例默认值' ;;
    invalid) printf '格式无效' ;;
    contract_mismatch) printf '与 Client/Gateway 协议不一致' ;;
    standalone_dependency) printf '当前为独立部署，请填写外部依赖地址' ;;
    *) printf '%s' "$1" ;;
  esac
}

issue_exists() {
  local target_key="$1"
  local idx
  for idx in "${!ISSUE_KEYS[@]}"; do
    if [[ "${ISSUE_KEYS[$idx]}" == "$target_key" ]]; then
      return 0
    fi
  done
  return 1
}

add_issue() {
  local key="$1"
  local reason="$2"
  if issue_exists "$key"; then
    return 0
  fi
  ISSUE_KEYS+=("$key")
  ISSUE_REASONS+=("$reason")
}

collect_config_issues() {
  local database_url postgres_password jwt_secret admin_username admin_password
  local dashboard_gateway_url client_gateway_url registry_raw device_id device_key registry_secret
  local deploys_postgres=0 deploys_gateway=0 deploys_client=0 deploys_dashboard=0
  local uses_external_database=0 uses_remote_gateway_for_client=0 uses_remote_gateway_for_dashboard=0

  normalize_targets full "$@"
  if array_contains postgres "${TARGETS[@]}"; then
    deploys_postgres=1
  fi
  if array_contains gateway "${TARGETS[@]}"; then
    deploys_gateway=1
  fi
  if array_contains client "${TARGETS[@]}"; then
    deploys_client=1
  fi
  if array_contains dashboard "${TARGETS[@]}"; then
    deploys_dashboard=1
  fi
  if [[ $deploys_gateway -eq 1 && $deploys_postgres -eq 0 ]]; then
    uses_external_database=1
  fi
  if [[ $deploys_client -eq 1 && $deploys_gateway -eq 0 ]]; then
    uses_remote_gateway_for_client=1
  fi
  if [[ $deploys_dashboard -eq 1 && $deploys_gateway -eq 0 ]]; then
    uses_remote_gateway_for_dashboard=1
  fi

  ISSUE_KEYS=()
  ISSUE_REASONS=()

  if [[ $deploys_postgres -eq 1 ]]; then
    postgres_password="$(trim "${EFFECTIVE_VALUES[POSTGRES_PASSWORD]-}")"
    if [[ -z "$postgres_password" ]]; then
      add_issue POSTGRES_PASSWORD missing
    elif [[ "$postgres_password" == "$POSTGRES_PASSWORD_DEFAULT" ]]; then
      add_issue POSTGRES_PASSWORD example_default
    fi
  fi

  database_url="$(trim "${EFFECTIVE_VALUES[DATABASE_URL]-}")"
  if [[ $uses_external_database -eq 1 ]] && database_url_needs_external_dependency "$database_url"; then
    add_issue DATABASE_URL standalone_dependency
  fi

  if [[ $deploys_gateway -eq 1 ]]; then
    jwt_secret="$(trim "${EFFECTIVE_VALUES[OMNI_AGENT_JWT_SECRET]-}")"
    if [[ -z "$jwt_secret" ]]; then
      add_issue OMNI_AGENT_JWT_SECRET missing
    elif [[ "$jwt_secret" == "$JWT_SECRET_DEFAULT" ]]; then
      add_issue OMNI_AGENT_JWT_SECRET example_default
    fi

    admin_username="$(trim "${EFFECTIVE_VALUES[OMNI_AGENT_ADMIN_USERNAME]-}")"
    [[ -n "$admin_username" ]] || add_issue OMNI_AGENT_ADMIN_USERNAME missing

    admin_password="$(trim "${EFFECTIVE_VALUES[OMNI_AGENT_ADMIN_PASSWORD]-}")"
    if [[ -z "$admin_password" ]]; then
      add_issue OMNI_AGENT_ADMIN_PASSWORD missing
    elif [[ "$admin_password" == "$ADMIN_PASSWORD_DEFAULT" ]]; then
      add_issue OMNI_AGENT_ADMIN_PASSWORD example_default
    fi
  fi

  if [[ $uses_remote_gateway_for_dashboard -eq 1 ]]; then
    dashboard_gateway_url="$(trim "${EFFECTIVE_VALUES[VITE_GATEWAY_BASE_URL]-}")"
    if ! is_absolute_http_url "$dashboard_gateway_url" || has_compose_only_hostname "$dashboard_gateway_url" gateway; then
      add_issue VITE_GATEWAY_BASE_URL standalone_dependency
    fi
  fi

  if [[ $uses_remote_gateway_for_client -eq 1 ]]; then
    client_gateway_url="$(trim "${EFFECTIVE_VALUES[OMNI_AGENT_GATEWAY_URL]-}")"
    if ! is_absolute_http_url "$client_gateway_url" || has_compose_only_hostname "$client_gateway_url" gateway localhost; then
      add_issue OMNI_AGENT_GATEWAY_URL standalone_dependency
    fi
  fi

  if [[ $deploys_client -eq 1 ]]; then
    registry_raw="$(trim "${EFFECTIVE_VALUES[OMNI_AGENT_DEVICE_KEYS]-}")"
    if [[ $uses_remote_gateway_for_client -eq 0 ]]; then
      if [[ -z "$registry_raw" ]]; then
        add_issue OMNI_AGENT_DEVICE_KEYS missing
      elif ! parse_device_registry "$registry_raw"; then
        add_issue OMNI_AGENT_DEVICE_KEYS invalid
      fi
    fi

    device_id="$(trim "${EFFECTIVE_VALUES[OMNI_AGENT_DEVICE_ID]-}")"
    [[ -n "$device_id" ]] || add_issue OMNI_AGENT_DEVICE_ID missing

    device_key="$(trim "${EFFECTIVE_VALUES[OMNI_AGENT_DEVICE_KEY]-}")"
    if [[ -z "$device_key" ]]; then
      add_issue OMNI_AGENT_DEVICE_KEY missing
    elif [[ "$device_key" == "$DEVICE_KEY_DEFAULT" ]]; then
      add_issue OMNI_AGENT_DEVICE_KEY example_default
    fi

    if [[ $uses_remote_gateway_for_client -eq 0 && -n "$registry_raw" ]] && parse_device_registry "$registry_raw"; then
      registry_secret="$(registry_get_secret "$device_id" || true)"
      if [[ -n "$device_id" && -n "$device_key" && -n "$registry_secret" && "$registry_secret" != "$device_key" ]]; then
        add_issue OMNI_AGENT_DEVICE_KEYS contract_mismatch
      fi
    fi
  fi
}

filter_issues() {
  local ordered_key idx
  FILTERED_ISSUE_KEYS=()
  FILTERED_ISSUE_REASONS=()
  for ordered_key in "${ISSUE_ORDER[@]}"; do
    for idx in "${!ISSUE_KEYS[@]}"; do
      if [[ "${ISSUE_KEYS[$idx]}" != "$ordered_key" ]]; then
        continue
      fi
      if [[ "${ISSUE_REASONS[$idx]}" == "example_default" && -n "${SKIPPED_DEFAULT_KEYS[$ordered_key]-}" ]]; then
        continue
      fi
      FILTERED_ISSUE_KEYS+=("$ordered_key")
      FILTERED_ISSUE_REASONS+=("${ISSUE_REASONS[$idx]}")
    done
  done
}

write_env_file() {
  local tmp_file raw_line key
  local -A emitted=()
  local extra_keys=()

  mkdir -p "$(dirname "$ENV_FILE")"
  tmp_file="$(mktemp)"

  for raw_line in "${TEMPLATE_LINES[@]}"; do
    if is_assignment_line "$raw_line"; then
      key="$(assignment_key "$raw_line")"
      emitted["$key"]=1
      printf '%s=%s\n' "$key" "${EFFECTIVE_VALUES[$key]-}" >> "$tmp_file"
    else
      printf '%s\n' "$raw_line" >> "$tmp_file"
    fi
  done

  for key in "${!EFFECTIVE_VALUES[@]}"; do
    if [[ -z "${emitted[$key]-}" ]]; then
      extra_keys+=("$key")
    fi
  done

  if [[ ${#extra_keys[@]} -gt 0 ]]; then
    mapfile -t extra_keys < <(printf '%s\n' "${extra_keys[@]}" | sort)
    printf '\n' >> "$tmp_file"
    for key in "${extra_keys[@]}"; do
      printf '%s=%s\n' "$key" "${EFFECTIVE_VALUES[$key]}" >> "$tmp_file"
    done
  fi

  mv "$tmp_file" "$ENV_FILE"
}

prompt_for_issue() {
  local key="$1"
  local reason="$2"
  local current_value="$3"
  local label service help_text default_hint answer

  label="$(field_label "$key")"
  service="$(field_service "$key")"
  help_text="$(field_help "$key")"
  if field_is_secret "$key" && [[ -n "$current_value" ]]; then
    default_hint="<已设置>"
  else
    default_hint="${current_value:-<空>}"
  fi

  echo
  echo "[$service] $label · $(reason_text "$reason")"
  [[ -n "$help_text" ]] && echo "提示：$help_text"
  if [[ "$reason" == "example_default" ]]; then
    echo "说明：当前值还是示例值，建议现在改掉；直接回车可暂时保留。"
  elif [[ "$reason" == "contract_mismatch" ]]; then
    echo "说明：脚本会把 Gateway 设备注册表与 Client 设备身份自动对齐。"
  elif [[ "$reason" == "standalone_dependency" ]]; then
    echo "说明：当前目标未部署本地依赖，必须填写一个可直接连接的外部地址。"
  fi

  while true; do
    printf '请输入（当前 %s）: ' "$default_hint"
    if field_is_secret "$key"; then
      read -r -s answer || exit 130
      printf '\n'
    else
      read -r answer || exit 130
    fi

    answer="$(trim "$answer")"
    if [[ -n "$answer" ]]; then
      PROMPT_RESULT="$answer"
      PROMPT_SKIPPED="0"
      return 0
    fi
    if [[ "$reason" == "example_default" && -n "$current_value" ]]; then
      PROMPT_RESULT="$current_value"
      PROMPT_SKIPPED="1"
      return 0
    fi
    echo "当前值仍不满足部署要求，请重新输入。"
  done
}

print_header() {
  echo "╔══════════════════════════════╗"
  echo "║ OpenJarvis Bash 部署助手 v1 ║"
  echo "╚══════════════════════════════╝"
}

load_state() {
  load_template
  load_env_file
  build_effective_values
}

run_config_wizard() {
  local idx key reason current_value
  local target_args=("$@")
  SKIPPED_DEFAULT_KEYS=()
  load_state
  if [[ -n "$REQUESTED_NETWORK_PROFILE" ]]; then
    ENV_VALUES[DEPLOY_NETWORK_PROFILE]="$REQUESTED_NETWORK_PROFILE"
    build_effective_values
  fi
  print_header
  echo "配置文件：$ENV_FILE"
  if [[ ! -f "$ENV_FILE" ]]; then
    echo "检测到 .env 不存在，将基于 .env.example 自动生成。"
  fi

  while true; do
    build_effective_values
    collect_config_issues "${target_args[@]}"
    filter_issues

    if [[ ${#FILTERED_ISSUE_KEYS[@]} -eq 0 ]]; then
      write_env_file
      echo
      echo "✅ 配置检查通过，已写入 .env"
      return 0
    fi

    echo
    echo "待处理配置项："
    for idx in "${!FILTERED_ISSUE_KEYS[@]}"; do
      echo "- ${FILTERED_ISSUE_KEYS[$idx]}: $(reason_text "${FILTERED_ISSUE_REASONS[$idx]}")"
    done

    key="${FILTERED_ISSUE_KEYS[0]}"
    reason="${FILTERED_ISSUE_REASONS[0]}"
    current_value="${EFFECTIVE_VALUES[$key]-}"
    prompt_for_issue "$key" "$reason" "$current_value"

    ENV_VALUES["$key"]="$PROMPT_RESULT"
    if [[ "$PROMPT_SKIPPED" == "1" ]]; then
      SKIPPED_DEFAULT_KEYS["$key"]=1
    else
      unset "SKIPPED_DEFAULT_KEYS[$key]" || true
    fi

    build_effective_values
    write_env_file
    echo "已更新 .env，继续检查剩余配置…"
  done
}

build_compose_command() {
  local action="$1"
  shift || true

  case "$action" in
    deploy)
      resolve_deploy_services "$@"
      COMPOSE_CMD=(docker compose up -d --build)
      if should_skip_compose_dependencies "${RESOLVED_SERVICES[@]}"; then
        COMPOSE_CMD+=(--no-deps)
      fi
      COMPOSE_CMD+=("${RESOLVED_SERVICES[@]}")
      ;;
    status)
      normalize_targets full "$@"
      COMPOSE_CMD=(docker compose ps "${TARGETS[@]}")
      ;;
    logs)
      normalize_targets runtime "$@"
      COMPOSE_CMD=(docker compose logs -f "${TARGETS[@]}")
      ;;
    stop)
      normalize_targets full "$@"
      COMPOSE_CMD=(docker compose stop "${TARGETS[@]}")
      ;;
    *)
      echo "不支持的动作: $action" >&2
      exit 1
      ;;
  esac
}

require_docker() {
  if [[ "$DRY_RUN" == "1" ]]; then
    return 0
  fi
  command -v docker >/dev/null 2>&1 || {
    echo "未检测到 docker，请先安装 Docker / Docker Compose。" >&2
    exit 1
  }
  docker compose version >/dev/null 2>&1 || {
    echo "检测不到 docker compose，请确认 Docker Compose 已可用。" >&2
    exit 1
  }
}

run_compose_action() {
  local action="$1"
  shift || true
  build_compose_command "$action" "$@"
  require_docker
  echo
  echo "\$ ${COMPOSE_CMD[*]}"
  if [[ "$DRY_RUN" == "1" ]]; then
    return 0
  fi
  (
    cd "$ROOT_DIR"
    "${COMPOSE_CMD[@]}"
  )
}

print_access_summary() {
  local dashboard_port gateway_port
  normalize_targets full "$@"
  dashboard_port="${EFFECTIVE_VALUES[DASHBOARD_PORT]-8080}"
  gateway_port="${EFFECTIVE_VALUES[GATEWAY_PORT]-8000}"
  echo
  echo "访问入口："
  if array_contains dashboard "${TARGETS[@]}"; then
    echo "- Dashboard: http://localhost:${dashboard_port}/jarvis/dashboard/"
  fi
  if array_contains gateway "${TARGETS[@]}"; then
    echo "- Gateway 健康检查: http://localhost:${gateway_port}/health"
  fi
  if [[ ${#TARGETS[@]} -eq 1 && "${TARGETS[0]}" == "client" ]]; then
    echo "- Client 远端 Gateway: ${EFFECTIVE_VALUES[OMNI_AGENT_GATEWAY_URL]-<未配置>}"
  fi
}

prompt_for_targets() {
  local selection
  while true; do
    printf '请输入目标（all/postgres/gateway/client/dashboard，空=all，可空格或逗号分隔）: '
    read -r selection || return 130
    selection="$(trim "$selection")"
    if [[ -z "$selection" ]]; then
      REQUESTED_TARGET_ARGS=()
      return 0
    fi
    selection="${selection//,/ }"
    read -r -a REQUESTED_TARGET_ARGS <<< "$selection"
    if normalize_targets full "${REQUESTED_TARGET_ARGS[@]}"; then
      return 0
    fi
    echo "目标无效，请重新输入。"
  done
}

prompt_for_network_profile() {
  local current_profile selection
  current_profile="$(trim "${EFFECTIVE_VALUES[DEPLOY_NETWORK_PROFILE]-global}")"
  [[ -n "$current_profile" ]] || current_profile="global"
  while true; do
    printf '请输入网络档位（global/cn，空=沿用 %s）: ' "$current_profile"
    read -r selection || return 130
    selection="$(trim "$selection")"
    if [[ -z "$selection" ]]; then
      REQUESTED_NETWORK_PROFILE="$current_profile"
      return 0
    fi
    case "$selection" in
      global|cn)
        REQUESTED_NETWORK_PROFILE="$selection"
        return 0
        ;;
      *)
        echo "网络档位无效，请输入 global 或 cn。"
        ;;
    esac
  done
}

show_menu() {
  load_state
  collect_config_issues
  filter_issues
  print_header
  if [[ ${#FILTERED_ISSUE_KEYS[@]} -eq 0 ]]; then
    echo "当前配置状态：已就绪"
  else
    echo "当前配置状态：待处理 ${#FILTERED_ISSUE_KEYS[@]} 项"
  fi
  echo
  echo "1) 检查并补全 .env"
  echo "2) 选择并部署目标端"
  echo "3) 查看服务状态"
  echo "4) 跟踪实时日志"
  echo "5) 停止服务"
  echo "q) 退出"
}

run_menu() {
  local choice
  while true; do
    show_menu
    printf '\n请选择操作: '
    read -r choice || return 130
    choice="$(trim "$choice")"
    case "$choice" in
      1)
        prompt_for_targets || return 130
        load_state
        prompt_for_network_profile || return 130
        run_config_wizard "${REQUESTED_TARGET_ARGS[@]}"
        REQUESTED_NETWORK_PROFILE=""
        echo
        ;;
      2)
        prompt_for_targets || return 130
        load_state
        prompt_for_network_profile || return 130
        run_config_wizard "${REQUESTED_TARGET_ARGS[@]}"
        run_compose_action deploy "${REQUESTED_TARGET_ARGS[@]}"
        print_access_summary "${REQUESTED_TARGET_ARGS[@]}"
        REQUESTED_NETWORK_PROFILE=""
        return 0
        ;;
      3)
        prompt_for_targets || return 130
        run_compose_action status "${REQUESTED_TARGET_ARGS[@]}"
        return 0
        ;;
      4)
        prompt_for_targets || return 130
        run_compose_action logs "${REQUESTED_TARGET_ARGS[@]}"
        return 0
        ;;
      5)
        prompt_for_targets || return 130
        run_compose_action stop "${REQUESTED_TARGET_ARGS[@]}"
        return 0
        ;;
      q|quit|exit)
        return 0
        ;;
      *)
        echo "无效选择，请输入 1/2/3/4/5/q。"
        echo
        ;;
    esac
  done
}

case "$ACTION" in
  menu)
    run_menu
    ;;
  config)
    run_config_wizard "${CLI_TARGET_ARGS[@]}"
    ;;
  deploy)
    run_config_wizard "${CLI_TARGET_ARGS[@]}"
    run_compose_action deploy "${CLI_TARGET_ARGS[@]}"
    print_access_summary "${CLI_TARGET_ARGS[@]}"
    ;;
  status)
    run_compose_action status "${CLI_TARGET_ARGS[@]}"
    ;;
  logs)
    run_compose_action logs "${CLI_TARGET_ARGS[@]}"
    ;;
  stop)
    run_compose_action stop "${CLI_TARGET_ARGS[@]}"
    ;;
  -h|--help|help)
    cat <<'EOF'
usage: ./jarvisctl [menu|config|deploy|status|logs|stop] [targets...]

targets:
  all        部署 postgres + gateway + client + dashboard
  postgres   单独部署内置 PostgreSQL
  gateway    单独部署 gateway，需在 .env 配置 DATABASE_URL
  client     单独部署 client，需在 .env 配置远端 OMNI_AGENT_GATEWAY_URL
  dashboard  单独部署 dashboard，需在 .env 配置远端 VITE_GATEWAY_BASE_URL

examples:
  ./jarvisctl
  ./jarvisctl deploy postgres
  ./jarvisctl deploy gateway
  ./jarvisctl deploy dashboard
  ./jarvisctl logs client

network profile:
  在 .env 中设置 DEPLOY_NETWORK_PROFILE=cn
  脚本会自动切到 gateway/client/dashboard 的国内加速构建链路
EOF
    ;;
  *)
    echo "未知命令: $ACTION" >&2
    exit 1
    ;;
esac
